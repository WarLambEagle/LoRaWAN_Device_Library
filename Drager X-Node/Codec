            }
       
    	var TYPE_HUMIDITY =decodeMeasuredValue(bytes, 18);
            //if (TYPE_TEMPERATURE > 32767) {
              //TYPE_TEMPERATURE -= 65536;
            //}
      
     //var TYPE_AIR_PRESSURE =decodeMeasuredValue(bytes, 22);
      
        var gas = {};
        gas.value = decodeFloat(bytes, index, index += 4);
        gas.unit = decodeUnit(bytes, index, index += 1);
        gas.name = decodeText(bytes, index, index += 4);
        
        
        //var TYPE_TEMPERATURE = 15;
        //var TYPE_HUMIDITY = 20;
        //var TYPE_AIR_PRESSURE = 25;
        var TYPE_METRICS = gas;
