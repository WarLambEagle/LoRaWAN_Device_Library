			TYPE_HUMIDITY:TYPE_HUMIDITY * 2 / 1000,
			//TYPE_AIR_PRESSURE:1469 - 0.0078125 * TYPE_AIR_PRESSURE,
			TYPE_METRICS:TYPE_METRICS,
			//TYPE_DEVICE:TYPE_DEVICE,
        };
    return decoded;
   }
